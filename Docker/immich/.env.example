# Pin to a specific release (e.g. v1.124.0) for reproducible upgrades, or leave as "release" for latest.
IMMICH_VERSION=release

# Where uploaded photos and videos are stored on the host. Must exist and be writable.
UPLOAD_LOCATION=/home/joseph/immich/library

# Where the Postgres data directory lives on the host. Must exist and be writable.
DB_DATA_LOCATION=/home/joseph/immich/postgres

# Where automated backups are written. The db-backup and uploads-backup services
# create db/ and uploads/ subdirectories here. Point this at a separate disk or mount
# (e.g. an external drive or NAS share) so a disk failure does not take backups with it.
BACKUP_LOCATION=/mnt/backups/immich

# Postgres credentials. Change DB_PASSWORD before first start.
DB_PASSWORD=postgres
DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# Timezone used by the server for date display.
TZ=America/New_York
