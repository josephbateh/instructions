# Host user that owns the Jellyfin config and media files. Run `id` on the
# host to find these. Jellyfin will read/write files as this user.
PUID=1000
PGID=1000

# Host's "render" group GID — the group that owns /dev/dri/renderD128.
# Required for Intel iGPU hardware transcoding. Find it with:
#   getent group render | cut -d: -f3
# On most Ubuntu/Debian hosts this is 989 or 993; on Arch it is often 998.
RENDER_GID=989

# Timezone used by the server for date display and scheduled tasks.
TZ=America/New_York

# Where Jellyfin stores config, users, library metadata, plugins. Backed up nightly.
CONFIG_LOCATION=/home/joseph/jellyfin/config

# Where Jellyfin stores transcoder and image cache. Regenerable — not backed up.
CACHE_LOCATION=/home/joseph/jellyfin/cache

# Your media library. Mount as many subdirectories as you like by changing the
# compose volume line, or point this at a parent directory that contains
# movies/, tvshows/, music/, etc.
MEDIA_LOCATION=/home/joseph/media

# Where automated config backups are written. Point this at a separate disk
# or mount than CONFIG_LOCATION so a single disk failure cannot destroy both.
BACKUP_LOCATION=/mnt/backups/jellyfin

# Optional: the URL clients should use to reach this server (e.g. https://jellyfin.example.com).
# Leave blank if you only access Jellyfin on the LAN by IP.
PUBLISHED_SERVER_URL=
